{
  "name": "goalpath",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsdown && vite build",
    "build:main": "tsdown",
    "build:renderer": "vite build",
    "start": "node scripts/start.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke:slice1": "tsx scripts/smoke-slice1.ts",
    "smoke:composio": "tsx --env-file=.env.local scripts/smoke-composio.ts",
    "smoke:context": "tsx --env-file=.env.local scripts/smoke-context.ts"
  },
  "dependencies": {
    "@composio/core": "^0.10.0",
    "@tanstack/react-query": "^5.90.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.564.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.2.0",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
